# Environment Variables for Dark Psychology Automation
# Copy this to .env and fill in your actual API keys

# AI Service APIs
OPENAI_API_KEY=your-openai-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
MIDJOURNEY_API_KEY=your-midjourney-api-key-here

# Social Media Posting API
AYRSHARE_API_KEY=your-ayrshare-api-key-here

# Social Media Account Details
INSTAGRAM_USERNAME=your_instagram_username
TIKTOK_USERNAME=your_tiktok_username
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# Content Settings
CHANNEL_NAME=The Dark Codex
VIDEO_LENGTH_SECONDS=50
HOOK_LENGTH_SECONDS=3
SCRIPT_LENGTH_SECONDS=45